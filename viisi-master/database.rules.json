{
  "rules": {
    "config": {
      ".read": true,
      ".write": true
    },
    "matches": {
      ".read": true,
      ".write": true,
      ".indexOn": ["_order"]
    },
    "partner": {
      ".read": true,
      ".write": true,
      "returns": {
        ".indexOn": ["_order", "date"]
      }
    },
    "tournament-queue": {
      ".read": true,
      "$id": {
        ".write": "!data.exists() || newData.child('status').val() !== data.child('status').val()",
        ".validate": "newData.hasChildren(['url', 'timestamp'])"
      },
      ".indexOn": ["status", "timestamp"]
    }
  }
}
