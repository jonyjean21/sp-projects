{
  "rules": {
    "config": {
      ".read": true,
      ".write": true
    },
    "matches": {
      ".read": true,
      ".write": true,
      ".indexOn": ["_order"]
    },
    "partner": {
      ".read": true,
      ".write": true,
      "returns": {
        ".indexOn": ["_order", "date"]
      }
    },
    "chapche-queue": {
      ".read": true,
      ".write": true,
      ".indexOn": ["status"]
    },
    "chapche-log": {
      ".read": true,
      ".write": true
    },
    "tournament-queue": {
      ".read": true,
      "$id": {
        ".write": "!data.exists() || newData.child('status').val() !== data.child('status').val()",
        ".validate": "newData.hasChildren(['url', 'timestamp'])"
      },
      ".indexOn": ["status", "timestamp"]
    },
    "machap": {
      ".read": true,
      ".write": true
    },
    "inbox": {
      ".read": true,
      ".write": true,
      ".indexOn": ["classification", "status", "created"]
    },
    "teamride": {
      ".read": true,
      ".write": true
    },
    "championship-2026": {
      ".read": true,
      ".write": true
    },
    "line-logs": {
      ".read": true,
      ".write": true,
      "$userId": {
        ".indexOn": ["timestamp"]
      }
    },
    "line-memories": {
      ".read": true,
      ".write": true,
      ".indexOn": ["timestamp", "userId"]
    },
    "contribution-queue": {
      ".read": true,
      ".write": true,
      ".indexOn": ["status", "timestamp"]
    },
    "claude-tips-queue": {
      ".read": true,
      ".write": true,
      ".indexOn": ["status", "timestamp"]
    },
    "buildhub-queue": {
      ".read": true,
      ".write": true,
      ".indexOn": ["status", "timestamp"]
    }
  }
}
